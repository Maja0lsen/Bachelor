   "source": [
    "### Hausman test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "82e71105",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hausman test statistic: 7489.00847061802\n",
      "p-value: 0.0\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "from scipy.stats import chi2\n",
    "\n",
    "# Hent koefficienter (kun fælles variable)\n",
    "fe_params = fe.params[[\"ctfp\", \"Age_dependency_old\", \"hc\", \"recession\"]]\n",
    "re_params = re.params[[\"ctfp\", \"Age_dependency_old\", \"hc\", \"recession\"]]\n",
    "\n",
    "fe_cov = fe.cov.loc[fe_params.index, fe_params.index]\n",
    "re_cov = re.cov.loc[re_params.index, re_params.index]\n",
    "\n",
    "diff = fe_params - re_params\n",
    "\n",
    "stat = np.dot(np.dot(diff.T, np.linalg.inv(fe_cov - re_cov)), diff)\n",
    "\n",
    "df = len(diff)\n",
    "p_value = 1 - chi2.cdf(stat, df)\n",
    "\n",
    "print(\"Hausman test statistic:\", stat)\n",
    "print(\"p-value:\", p_value)"
   ]
  },
