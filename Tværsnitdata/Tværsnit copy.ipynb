    "# Samlet kode for deskriptiv statistik\n",
    "import pandas as pd\n",
    "\n",
    "def beskriv_data(df):\n",
    "    desc = df.describe(percentiles=[.25, .5, .75]).T\n",
    "    desc = desc.rename(columns={\n",
    "        '25%': '25%-percentil',\n",
    "        '50%': 'Median',\n",
    "        '75%': '75%-percentil',\n",
    "        'std': 'Std. afvigelse',\n",
    "        'mean': 'Gennemsnit',\n",
    "        'min': 'Minimum',\n",
    "        'max': 'Maksimum',\n",
    "        'count': 'Antal'\n",
    "    })\n",
    "    return desc[['Antal', 'Gennemsnit', 'Std. afvigelse', 'Minimum', '25%-percentil', 'Median', '75%-percentil', 'Maksimum']]\n",
    "\n",
    "# Eksempel på brug:\n",
    "deskriptiv = beskriv_data(Tvaersnit)\n",
    "print(deskriptiv)\n",
    "\n",
    "# For kategoriske variable:\n",
    "def beskriv_kategorisk(df):\n",
    "    for col in df.select_dtypes(include=['object', 'category']).columns:\n",
    "        print(f\"\\n{col}:\")\n",
    "        print(df[col].value_counts())\n",
    "        print(f\"Hyppigste værdi: {df[col].mode()[0]}\")\n",
    "\n",
    "# Eksempel på brug:\n",
    "beskriv_kategorisk(Tvaersnit)\n"
